{
  "name": "equation-connect",
  "homepage": "https://andremiras.github.io/equation-connect/",
  "version": "2022.03.30",
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-free": "^5.15.4",
    "@fortawesome/fontawesome-svg-core": "^1.2.36",
    "@fortawesome/free-brands-svg-icons": "^5.15.4",
    "@fortawesome/free-solid-svg-icons": "^5.15.4",
    "@fortawesome/react-fontawesome": "^0.1.16",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^12.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "bootstrap": "5.3.8",
    "equation-connect": "^1.7.0",
    "firebase": "^9.5.0",
    "react": "^18.2.0",
    "react-bootstrap": "^2.0.2",
    "react-dom": "^18.2.0",
    "react-open-weather": "^1.1.6",
    "react-router-dom": "^6.0.2",
    "react-scripts": "4.0.3",
    "typescript": "^5.9.3",
    "web-vitals": "^1.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx && prettier --check .",
    "lint:eslint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:prettier": "prettier --check .",
    "format": "prettier --write . && eslint --fix src --ext .js,.jsx,.ts,.tsx",
    "format:eslint": "eslint --fix src --ext .js,.jsx,.ts,.tsx",
    "format:prettier": "prettier --write .",
    "predeploy": "yarn run build",
    "deploy": "gh-pages -d build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "plugins": [
      "simple-import-sort"
    ],
    "rules": {
      "react/jsx-uses-react": "off",
      "react/react-in-jsx-scope": "off",
      "@typescript-eslint/no-unused-vars": "error",
      "simple-import-sort/imports": "error",
      "simple-import-sort/exports": "error"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "resolutions": {
    "postcss-safe-parser/postcss": "~8.4.49",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0"
  },
  "devDependencies": {
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "gh-pages": "^3.2.3",
    "prettier": "^2.5.0"
  }
}
