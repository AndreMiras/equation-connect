{
  "name": "equation-connect",
  "homepage": "https://andremiras.github.io/equation-connect/",
  "version": "2022.03.30",
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bootstrap": "5.3.8",
    "equation-connect": "^1.7.0",
    "firebase": "^9.5.0",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.4",
    "react-open-weather": "^1.3.9",
    "react-router": "^7.13.1",
    "typescript": "^5.9.3",
    "web-vitals": "^5.1.0"
  },
  "scripts": {
    "start": "vite",
    "build": "VITE_GIT_DESCRIBE=$(git describe --tags --always) tsc --noEmit && VITE_GIT_DESCRIBE=$(git describe --tags --always) vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx && prettier --check .",
    "lint:eslint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:prettier": "prettier --check .",
    "format": "prettier --write . && eslint --fix src --ext .js,.jsx,.ts,.tsx",
    "format:eslint": "eslint --fix src --ext .js,.jsx,.ts,.tsx",
    "format:prettier": "prettier --write .",
    "predeploy": "yarn run build",
    "deploy": "gh-pages -d build"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "plugins": [
      "simple-import-sort"
    ],
    "rules": {
      "react/jsx-uses-react": "off",
      "react/react-in-jsx-scope": "off",
      "@typescript-eslint/no-unused-vars": "error",
      "simple-import-sort/imports": "error",
      "simple-import-sort/exports": "error"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "resolutions": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5",
    "@vitest/coverage-v8": "^3",
    "eslint": "^8",
    "eslint-config-react-app": "^7",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^26",
    "prettier": "^2.5.0",
    "vite": "^6",
    "vite-tsconfig-paths": "^6",
    "vitest": "^3"
  }
}
